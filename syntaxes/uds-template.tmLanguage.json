{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "uds-template",
  "scopeName": "source.uds-template",
  "patterns": [
    { "include": "#comments-hash" },
    { "include": "#comments-hash-log" },
    { "include": "#comments-hash-header" },
    { "include": "#comments-semicolon" },
    { "include": "#canape-commands" },
    { "include": "#expected-ini-patterns" },
    { "include": "#keywords-values" },
    { "include": "#uds-service-values" },
    { "include": "#if-block" },
    { "include": "#lauterbach-commands" }
  ],
  "repository": {
    "comments-hash": {
      "begin": "#(?!!|>#|>#>)",
      "end": "$",
      "name": "comment.line.hash.uds-template",
      "patterns": [
        { "include": "#expected-ini-patterns" },
        { "include": "#keywords-values" }
      ]
    },
    "comments-hash-log": {
      "begin": "#>+",
      "end": "$",
      "name": "comment.line.hash-log.uds-template",
      "patterns": [
        { "include": "#expected-ini-patterns" },
        { "include": "#keywords-values" }
      ]
    },
    "comments-hash-header": {
      "begin": "#>#+",
      "end": "$",
      "name": "comment.line.hash-header.uds-template",
      "patterns": [
          { "include": "#expected-ini-patterns" },
          { "include": "#keywords-values" }
      ]
    },
    "comments-semicolon": {
      "begin": ";(?!!)",
      "end": "$",
      "name": "comment.line.semicolon.uds-template",
      "patterns": [
        { "include": "#expected-ini-patterns" },
        { "include": "#keywords-values" }
      ]
    },
    "canape-commands": {
      "patterns": [
        {
          "name": "support.function.canape.uds-template",
          "match": "!\\b(prog|send|sleep|echo|dialog|baud|sa|repair|testerp|canid|pcheck|yield|suppress|set|batch|append|exit|auth|activate|canalyzer|append)\\b(?=\\()"
        },
        { "include": "#keywords-values" }
      ]
    },
    "expected-ini-patterns": {
      "patterns": [
        {
          "name": "keyword.control.expected.uds-template",
          "match": "\\$\\b(EXPECTED)\\b(?=\\()"
        }
      ]
    },
    "keywords-values":{
        "patterns": [
        {
            "name": "keyword.other.ini-reference.uds-template",
            "match": "@\\([^)]*\\)"
        },
            {
            "name": "keyword.other.ini-postprocess.uds-template",
            "match": "\\$\\([^()]*\\)"
        }
        ]
            
    },
    "uds-service-values": {
      "patterns": [
        {
          "name": "constant.numeric.uds-service.uds-template",
          "match": "\\b(?:[0-9A-Fa-f]{2}|@\\([^()]+\\))(?:,(?:[0-9A-Fa-f]{2}|@\\([^()]+\\)))+(?=\\s)"
        },
        {
          "name": "constant.numeric.uds-service.uds-template",
          "match": "\\b(?:[0-9A-Fa-f]{2}){2,}(?=\\s)"
        },
        { "include": "#keywords-values" }
      ]
    },
    "if-block": {
      "begin": "^\\s*(?i:@if)\\b.*$",
      "beginCaptures": {
        "0": { "name": "keyword.control.conditional.if.uds-template" }
      },
      "end": "^\\s*(?i:@endif)\\b.*$",
      "endCaptures": {
        "0": { "name": "keyword.control.conditional.endif.uds-template" }
      },
      "patterns": [
        {
          "match": "^\\s*(?i:@elif)\\b.*$",
          "name": "keyword.control.conditional.elif.uds-template"
        },
        {
          "match": "^\\s*(?i:@else)\\b.*$",
          "name": "keyword.control.conditional.else.uds-template"
        },
        { "include": "#comments-hash" },
        { "include": "#comments-hash-log" },
        { "include": "#comments-hash-header" },
        { "include": "#comments-semicolon" },
        { "include": "#canape-commands" },
        { "include": "#expected-ini-patterns" },
        { "include": "#keywords-values" },
        { "include": "#uds-service-values" },
        { "include": "#if-block" },
        { "include": "#lauterbach-commands" }
      ]
    },
    "lauterbach-commands":{
      "patterns": [
        {
            "name": "support.function.lauterbach.uds-template",
            "match": "\\b(?:SYStem|FLASH|Data|Break|Go|Step|HALT|WAIT|Register|Var|sYmbol|RUNTIME|PER|PRINT|AREA|DO|ENDDO|GOSUB|RETURN|ENTRY|PORST|EPORST)(?:\\.[A-Za-z]+)*\\b"
        },
        {
            "name": "constant.language.lauterbach.option.uds-template",
            "match": "\\/[A-Z][A-Z0-9]+"
        },
        {
            "name": "keyword.operator.lauterbach.macro.uds-template",
            "match": "%%(?:LE|BE|LONG|WORD|BYTE)\\b"
        },
        { "include": "#keywords-values" }
      ]
    }
  },
  "fileTypes": ["uds.template"],
  "uuid": "d0f1e432-7d39-11ee-b962-0242ac120002"

}
