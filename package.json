{
  "name": "uds-template-keaywords",
  "displayName": "uds-template-keaywords",
  "description": "Provides keywords suggesstion from INI file",
  "version": "0.3.0",
  "engines": {
    "vscode": "^1.102.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "uds-template-keaywords.helloWorld",
        "title": "Hello World"
      }
    ], 
    "languages": [
      {
        "id": "uds-template",
        "aliases": ["UDS Template", "uds-template"],
        "extensions": [".uds.template", ".uds"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "uds-template",
        "scopeName": "source.uds-template",
        "path": "./syntaxes/uds-template.tmLanguage.json"
      }
    ],
      "themes": [
        {
          "label": "UDS Template Dark",
          "uiTheme": "vs-dark",
          "path": "./themes/uds-template-dark-color-theme.json"
        },
        {
          "label": "UDS Template Light",
          "uiTheme": "vs",
          "path": "./themes/uds-template-light-color-theme.json"
        }
      ],
      "snippets": [
        {
          "language": "uds-template",
          "path": "./snippets/uds-template.code-snippets"
        }
      ],
      "configuration":[
        {
          "properties": {
            "uds-template.templatesFolder":{
              "type": "array",
              "default": ["TEMPLATES"],
              "description": "List of folders (which contain ini files) relative to workspace root."
            },
            "uds-template.iniSections": {
              "type": "array",
              "items": {"type": "string"},
              "default": ["common"],
              "description": "List of section names to read from INI files (CASE SENSITIVE)."
            },
            "uds-template.iniGlob": {
              "type": "string",
              "default": "**/*.ini",
              "description": "Glob pattern to find ini files inside the configured folders."
            }
            ,
            "uds-template.variant": {
              "type": "string",
              "default": "",
              "description": "Active variant name used for conditional highlighting (e.g. PT64). If empty, extension falls back to scanning INI values."
            }
          }
        }
      ]
      
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "build:vsix": "npm run compile && npx vsce package",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.102.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "ini": "^5.0.0"
  }
}
